# DeepSeek API（OpenAI 兼容）。没有 key 时应用自动使用内置模板兜底，demo 仍可运行。
# 申请：https://platform.deepseek.com/  —  填入后即切换为真实 AI 生成。
DEEPSEEK_API_KEY=
# 可选：默认 https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：默认 deepseek-chat（当前映射 deepseek-v4-flash 非思考模式）
DEEPSEEK_MODEL=deepseek-chat

# 每日配额（按设备，上海时区自然日）
# 完整合成成功计 1 次作品；删除不返还
DAILY_TRACK_LIMIT=2
# 肯定语 AI 调用上限（防刷）；用尽后走本地模板
DAILY_AI_CALL_LIMIT=8

# 反馈管理（站内回复入口）
FEEDBACK_ADMIN_PASSWORD=
# 可选：会话签名密钥；不填则使用 FEEDBACK_ADMIN_PASSWORD
FEEDBACK_ADMIN_SECRET=
# 飞书群机器人 Webhook：仅在新反馈提交时推送通知
LARK_FEEDBACK_WEBHOOK_URL=
# 可选：站点地址，用于飞书通知里的管理页直达链接
SITE_URL=https://ciery0003.cn
